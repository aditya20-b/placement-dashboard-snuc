# ─── NextAuth ───────────────────────────────────────────
# Local: http://localhost:3000 | Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Google OAuth ─────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Redirect URIs to register in Google Cloud Console:
#   http://localhost:3000/api/auth/callback/google
#   https://your-app.vercel.app/api/auth/callback/google

# ─── Google Sheets API ─────────────────────────────────
# Google Cloud Console → Service Account → Keys → JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full PEM key (with -----BEGIN/END-----) wrapped in double quotes
GOOGLE_PRIVATE_KEY=""
# From the Google Sheet URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
# Share the sheet with the service account email as Viewer
# Required tabs: Master, Offer Details, Access
GOOGLE_SHEET_ID=
